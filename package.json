    "@angular/core": "22.0.2",
    "@angular/platform-browser": "22.0.2",
    "@angular/router": "22.0.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.7.2",
    "nodemailer": "^7.0.11",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "22.0.3",
    "@angular/cli": "22.0.3",
    "@angular/compiler-cli": "22.0.2",
    "typescript": "6.0.3"
  }
}
