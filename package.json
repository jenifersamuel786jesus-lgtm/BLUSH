{
  "name": "blush-and-glow-angular",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node scripts/dev.js",
    "frontend": "ng serve --host 127.0.0.1 --port 4201 --proxy-config frontend/proxy.conf.json",
    "server": "cd backend && node server.js",
    "seed": "cd backend && node seed.js",
    "build": "ng build",
    "watch": "ng build --watch --configuration development"
  },
  "dependencies": {
    "@angular/common": "22.0.2",
